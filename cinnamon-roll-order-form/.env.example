# =============================================================
# Bachata Bakery — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# Environment: "sandbox" or "production"
APP_ENV=sandbox

# ------- Square -------
# Sandbox: https://developer.squareup.com/apps
# Production: flip APP_ENV and swap all three values
SQUARE_APP_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXXXXXX
SQUARE_LOCATION_ID=XXXXXXXXXXXXXXXX
SQUARE_ACCESS_TOKEN=EAAAl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SQUARE_WEBHOOK_SIG_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Full URL of this webhook as registered in the Square Developer Dashboard.
# Must match exactly (scheme + host + path). Used for HMAC signature validation.
WEBHOOK_URL=https://yourdomain.com/api/webhook/square.php

# ------- Database -------
DB_HOST=localhost
DB_NAME=bachata_bakery
DB_USER=
DB_PASS=

# ------- Email (Hostinger SMTP) -------
SMTP_HOST=smtp.hostinger.com
SMTP_USER=orders@bachatababakery.com
SMTP_PASS=
SMTP_PORT=465

# ------- App -------
OWNER_EMAIL=owner@bachatababakery.com
BAKERY_TIMEZONE=America/New_York
# Admin dashboard password — use a strong password (16+ chars)
ADMIN_PASS=changeme
